# 复制这个文件为 .env，填入真实 key，不要把 .env 提交到 git / 发给任何人（包括我）。

# 行为生成（Agent Loop / Baseline），必须
DEEPSEEK_API_KEY=

# LLM-as-a-Judge（评测），二选一即可：
# 1) 有 OpenAI key 用这个，judge 走 GPT-4o
OPENAI_API_KEY=
# 2) 没有 OpenAI key，用 Kimi（Moonshot，OpenAI 兼容接口）代替
MOONSHOT_API_KEY=
# 可选：覆盖默认的 Kimi judge 模型（默认 moonshot-v1-8k）
# KIMI_JUDGE_MODEL=moonshot-v1-8k
